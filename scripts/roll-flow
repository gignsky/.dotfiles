#!/usr/bin/env nu

# roll-flow: A git-flow-like workflow manager for NixOS dotfiles
# Manages roll/N-* branches, rolling integration, and main promotion

def main [] {
    print "roll-flow: NixOS dotfiles workflow manager"
    print ""
    print "Usage: roll-flow <command> [args]"
    print ""
    print "Commands:"
    print "  init                    Initialize roll-flow in this repo"
    print "  start <theme>           Start a new roll branch"
    print "  integrate <branch>      Merge a feature branch into current roll"
    print "  graduate                Graduate current roll to rolling branch"
    print "  promote                 Promote rolling to main (with verification)"
    print "  status                  Show current roll status"
    print "  test-all                Test build on all configured hosts"
    print "  list                    List all rolls and their states"
    print ""
    print "Examples:"
    print "  roll-flow start shell-improvements"
    print "  roll-flow integrate feature/zellij-config"
    print "  roll-flow graduate"
    print "  roll-flow promote"
}

# Initialize roll-flow configuration
def "main init" [] {
    let config_dir = $"($env.HOME)/.config/roll-flow"
    mkdir $config_dir
    
    let config = {
        repo_root: (git rev-parse --show-toplevel | str trim),
        rolling_branch: "rolling-transitional-phase",
        stable_branch: "main",
        roll_prefix: "roll/",
        hosts: ["ganoslal", "merlin", "wsl"]
    }
    
    $config | save -f $"($config_dir)/config.nuon"
    print $"✓ Initialized roll-flow in (ansi green)($config.repo_root)(ansi reset)"
}

# Get current configuration
def get-config [] {
    let config_file = $"($env.HOME)/.config/roll-flow/config.nuon"
    if not ($config_file | path exists) {
        error make {msg: "roll-flow not initialized. Run 'roll-flow init' first."}
    }
    open $config_file
}

# Get the next roll number
def get-next-roll-number [] {
    let config = get-config
    
    let rolls = (git branch --list $"($config.roll_prefix)*" 
        | lines 
        | each { |line| $line | str trim | str replace '* ' '' }
        | where { |branch| $branch =~ $"^($config.roll_prefix)" }
        | each { |branch| 
            $branch 
            | str replace $config.roll_prefix '' 
            | split row '-' 
            | get 0 
            | into int
        }
    )
    
    if ($rolls | is-empty) {
        1
    } else {
        ($rolls | math max) + 1
    }
}

# Get current active roll
def get-current-roll [] {
    let current_branch = (git branch --show-current | str trim)
    let config = get-config
    
    if ($current_branch | str starts-with $config.roll_prefix) {
        $current_branch
    } else {
        null
    }
}

# Start a new roll
def "main start" [
    theme: string  # Theme/description for this roll
] {
    let config = get-config
    let next_num = get-next-roll-number
    let date_str = (date now | format date "%m%d")
    let roll_name = $"($config.roll_prefix)($next_num)-($date_str)-($theme)"
    
    print $"Creating new roll: (ansi cyan)($roll_name)(ansi reset)"
    
    # Create roll from rolling branch
    git checkout $config.rolling_branch
    git pull
    git checkout -b $roll_name
    
    # Save roll metadata
    let rolls_dir = $"($env.HOME)/.config/roll-flow/rolls"
    mkdir $rolls_dir
    
    let metadata = {
        roll: $roll_name,
        number: $next_num,
        theme: $theme,
        started: (date now | format date "%Y-%m-%d %H:%M:%S"),
        status: "active",
        merged_features: []
    }
    
    $metadata | save -f $"($rolls_dir)/($next_num).nuon"
    
    print $"✓ Started roll (ansi green)($roll_name)(ansi reset)"
    print $"  Branch from: ($config.rolling_branch)"
    print $"  Now on: ($roll_name)"
}

# Integrate a feature branch into current roll
def "main integrate" [
    feature_branch: string  # Feature branch to integrate
] {
    let current_roll = get-current-roll
    
    if ($current_roll == null) {
        error make {msg: "Not currently on a roll branch. Run 'roll-flow start' first."}
    }
    
    print $"Integrating (ansi cyan)($feature_branch)(ansi reset) into (ansi cyan)($current_roll)(ansi reset)"
    
    # Merge with no-ff to preserve history
    git merge --no-ff $feature_branch
    
    if $env.LAST_EXIT_CODE == 0 {
        # Update metadata
        let roll_num = ($current_roll | str replace 'roll/' '' | split row '-' | get 0)
        let metadata_file = $"($env.HOME)/.config/roll-flow/rolls/($roll_num).nuon"
        
        if ($metadata_file | path exists) {
            mut metadata = (open $metadata_file)
            $metadata.merged_features = ($metadata.merged_features | append $feature_branch)
            $metadata | save -f $metadata_file
        }
        
        print $"✓ Integrated (ansi green)($feature_branch)(ansi reset)"
        print $"  You can now test with: just rebuild"
    } else {
        print $"✗ Merge failed. Resolve conflicts and commit manually."
    }
}

# Graduate current roll to rolling branch
def "main graduate" [] {
    let current_roll = get-current-roll
    let config = get-config
    
    if ($current_roll == null) {
        error make {msg: "Not currently on a roll branch."}
    }
    
    print $"Graduating (ansi cyan)($current_roll)(ansi reset) to (ansi cyan)($config.rolling_branch)(ansi reset)"
    print ""
    print "This will merge the current roll into rolling branch."
    print "Make sure you've tested this roll on at least one host!"
    print ""
    
    let confirm = (input "Continue? (yes/no): ")
    
    if $confirm != "yes" {
        print "Aborted."
        return
    }
    
    git checkout $config.rolling_branch
    git pull
    git merge --no-ff $current_roll
    
    if $env.LAST_EXIT_CODE == 0 {
        git push
        
        # Update metadata
        let roll_num = ($current_roll | str replace 'roll/' '' | split row '-' | get 0)
        let metadata_file = $"($env.HOME)/.config/roll-flow/rolls/($roll_num).nuon"
        
        if ($metadata_file | path exists) {
            mut metadata = (open $metadata_file)
            $metadata.status = "graduated"
            $metadata.graduated = (date now | format date "%Y-%m-%d %H:%M:%S")
            $metadata | save -f $metadata_file
        }
        
        print $"✓ Graduated (ansi green)($current_roll)(ansi reset) to ($config.rolling_branch)"
        print $"  Roll branch kept for reference (safe to delete later)"
    } else {
        print $"✗ Graduation failed. Check for conflicts."
    }
}

# Promote rolling to main
def "main promote" [] {
    let config = get-config
    
    print $"Promoting (ansi cyan)($config.rolling_branch)(ansi reset) to (ansi cyan)($config.stable_branch)(ansi reset)"
    print ""
    print "WARNING: This marks the rolling branch as stable for ALL hosts."
    print "Make sure you've tested on:"
    
    for host in $config.hosts {
        print $"  - ($host)"
    }
    
    print ""
    let confirm = (input "Have you tested on all hosts? (yes/no): ")
    
    if $confirm != "yes" {
        print "Aborted. Test on all hosts first!"
        return
    }
    
    git checkout $config.stable_branch
    git pull
    git merge --no-ff $config.rolling_branch
    
    if $env.LAST_EXIT_CODE == 0 {
        # Create dated tag
        let tag = $"stable-(date now | format date '%Y%m%d')"
        let tag_msg = $"Verified on: (config.hosts | str join ', ')"
        
        git tag -a $tag -m $tag_msg
        git push --tags
        git push
        
        print $"✓ Promoted to (ansi green)($config.stable_branch)(ansi reset)"
        print $"  Tagged as: ($tag)"
    } else {
        print $"✗ Promotion failed. Check for conflicts."
    }
}

# Show current status
def "main status" [] {
    let config = get-config
    let current_branch = (git branch --show-current | str trim)
    let current_roll = get-current-roll
    
    print "=== Roll Flow Status ==="
    print ""
    print $"Current branch: (ansi cyan)($current_branch)(ansi reset)"
    print $"Rolling branch: ($config.rolling_branch)"
    print $"Stable branch:  ($config.stable_branch)"
    print ""
    
    if ($current_roll != null) {
        print $"✓ On active roll: (ansi green)($current_roll)(ansi reset)"
        
        # Show roll details if available
        let roll_num = ($current_roll | str replace 'roll/' '' | split row '-' | get 0)
        let metadata_file = $"($env.HOME)/.config/roll-flow/rolls/($roll_num).nuon"
        
        if ($metadata_file | path exists) {
            let metadata = (open $metadata_file)
            print $"  Theme: ($metadata.theme)"
            print $"  Started: ($metadata.started)"
            print $"  Features integrated: ($metadata.merged_features | length)"
        }
    } else {
        print "ℹ Not on a roll branch"
    }
    
    print ""
    print "=== Recent Rolls ==="
    
    let rolls_dir = $"($env.HOME)/.config/roll-flow/rolls"
    if ($rolls_dir | path exists) {
        ls $rolls_dir 
        | where type == file 
        | get name 
        | each { |file| 
            let metadata = (open $file)
            let status_color = if $metadata.status == "active" { "green" } else { "yellow" }
            print $"  roll/($metadata.number) - ($metadata.theme) [(ansi ($status_color))($metadata.status)(ansi reset)]"
        }
    }
}

# Test build on all hosts
def "main test-all" [] {
    let config = get-config
    
    print "Testing builds on all configured hosts..."
    print ""
    
    for host in $config.hosts {
        print $"Building for (ansi cyan)($host)(ansi reset)..."
        
        try {
            nix build $".#homeConfigurations.($host).activationPackage" --show-trace
            print $"  ✓ (ansi green)($host) build succeeded(ansi reset)"
        } catch {
            print $"  ✗ (ansi red)($host) build failed(ansi reset)"
        }
        
        print ""
    }
}

# List all rolls
def "main list" [] {
    let config = get-config
    
    print "=== All Rolls ==="
    print ""
    
    git branch --list $"($config.roll_prefix)*"
    | lines
    | each { |line| 
        let branch = ($line | str trim | str replace '* ' '')
        let is_current = ($line | str starts-with '*')
        
        if $is_current {
            print $"  → (ansi green)($branch)(ansi reset) (current)"
        } else {
            print $"    ($branch)"
        }
    }
}
